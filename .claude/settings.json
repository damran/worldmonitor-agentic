{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "WebSearch",
      "Bash(git:*)", "Bash(gh:*)",
      "Bash(uv:*)", "Bash(python:*)", "Bash(python3:*)",
      "Bash(pytest:*)", "Bash(ruff:*)", "Bash(pyright:*)",
      "Bash(docker:*)", "Bash(docker compose:*)", "Bash(act:*)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(git push --force*)", "Bash(git push -f*)",
      "Read(./.env)", "Read(./.env.*)", "Read(**/.env)", "Read(**/secrets/**)"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "PreToolUse": [
      { "matcher": "Bash",
        "hooks": [ { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/no-master-commit.sh" } ] }
    ],
    "SubagentStop": [
      { "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/secret-scan.sh" },
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/scope-guard.sh" },
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/test-strictness.sh" }
        ] }
    ]
  }
}
