# WorldMonitor environment — copy to `.env` and fill in. NEVER commit `.env`.
# Placeholders only (no real secrets). Replace every `change-me`.

# --- App ---
ENVIRONMENT=development

# --- Zitadel / OIDC (the API validates bearer tokens against this) ---
# After `docker compose up`, run scripts/dev/zitadel_provision.sh to create the
# OIDC apps, then paste the values it prints below.
ZITADEL_DOMAIN=localhost:8080
ZITADEL_CLIENT_ID=

# --- Backing-service URLs the app connects to ---
NEO4J_URI=bolt://localhost:7687
POSTGRES_DSN=postgresql://worldmonitor:change-me@localhost:5432/worldmonitor
REDIS_URL=redis://:change-me@localhost:6379/0

# --- Entity resolution: catastrophic-merge guard (ADR 0024) ---
# "block" parks flagged (oversized / PEP / sanctioned) merges for human review;
# "alert" (BUILD-PHASE default) writes them anyway and records a merge_alerts row.
# MUST return to "block" with human sign-off before production.
MERGE_GUARD_MODE=alert
# Max ER-queue candidates resolved per batch (ADR 0026). resolve_pending drains
# the queue in windows of this size with a commit per batch; dedup is within a
# batch (cross-batch/incremental dedup is deferred to the ER-streaming gate).
RESOLVE_BATCH_SIZE=1000
# Ingest bounds + windowing (ADR 0027). run_ingest commits every N records, stops a
# run after the wall-clock deadline (<=0 disables), and optionally caps record count
# (unset = no cap). A bad record is dead-lettered, never aborts the run.
INGEST_COMMIT_EVERY=1000
INGEST_TIMEOUT_SECONDS=1800
# INGEST_MAX_RECORDS=

# --- Secrets ---
# Fernet key for encrypting connector configs at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONFIG_ENCRYPTION_KEY=change-me
MINIO_ENDPOINT=localhost:9000

# =====================================================================
# Compose stack credentials (deploy/compose.yaml)
# =====================================================================

# --- PostgreSQL 16 + pgvector ---
POSTGRES_USER=worldmonitor
POSTGRES_PASSWORD=change-me
POSTGRES_DB=worldmonitor
ZITADEL_DB=zitadel

# --- Neo4j 2026.x + GDS ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
NEO4J_PAGECACHE=512m

# --- MinIO ---
MINIO_ROOT_USER=worldmonitor
MINIO_ROOT_PASSWORD=change-me
# The app's S3 credentials (must match the root creds above) + landing bucket.
MINIO_ACCESS_KEY=worldmonitor
MINIO_SECRET_KEY=change-me
LANDING_BUCKET=landing

# --- Redis ---
REDIS_PASSWORD=change-me

# --- Zitadel ---
# ZITADEL_MASTERKEY MUST be exactly 32 characters.
ZITADEL_MASTERKEY=change-me-32-chars-xxxxxxxxxxxxx
ZITADEL_EXTERNALDOMAIN=localhost
ZITADEL_EXTERNALPORT=8080
ZITADEL_ORG_NAME=WorldMonitor
ZITADEL_ADMIN_USERNAME=admin
ZITADEL_ADMIN_PASSWORD=change-me
ZITADEL_ADMIN_EMAIL=admin@worldmonitor.localhost
ZITADEL_SA_USERNAME=provisioner
