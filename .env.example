# WorldMonitor environment — copy to `.env` and fill in. NEVER commit `.env`.
# Placeholders only (no real secrets). Replace every `change-me`.
# Non-development boots (ENVIRONMENT != development) REJECT `change-me` placeholders at
# startup and halt loud (ADR 0061) — fill in real secrets before deploying.
# Drift guard: tests/unit/test_env_example_drift.py fails if a Settings field is missing here.

# --- App ---
ENVIRONMENT=development

# --- Zitadel / OIDC (the API validates bearer tokens against this) ---
# After `docker compose up`, run scripts/dev/zitadel_provision.sh to create the
# OIDC apps, then paste the values it prints below.
ZITADEL_DOMAIN=localhost:8080
ZITADEL_CLIENT_ID=
# Browser OIDC (ADR 0068): the confidential-client secret + the session-cookie signing key.
# BOTH are enforced on any non-development boot (ADR 0061/0068): SESSION_SECRET_KEY
# unconditionally (the session cookie is signed on every boot, auth wired or not);
# ZITADEL_CLIENT_SECRET once auth is configured. Leaving them placeholder HALTS the boot.
ZITADEL_CLIENT_SECRET=
SESSION_SECRET_KEY=change-me
# Absolute public base URL (e.g. https://wm.example.com) used to build the OIDC
# redirect_uri (APP_BASE_URL + /auth/callback) — NOT a Host-derived URL (ADR 0068).
APP_BASE_URL=

# --- MCP server transport (Phase-3 S1, ADR 0090) ---
# stdio (default) = local trust boundary, no port. Set `streamable-http` to serve the
# authenticated HTTP transport a remote Hermes connects to (always bearer-gated).
MCP_TRANSPORT=stdio
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8765
# Optional RFC 9728 protected-resource metadata URL for the MCP server (empty = omitted).
MCP_RESOURCE_SERVER_URL=

# --- Backing-service URLs the app connects to ---
NEO4J_URI=bolt://localhost:7687
POSTGRES_DSN=postgresql://worldmonitor:change-me@localhost:5432/worldmonitor
REDIS_URL=redis://:change-me@localhost:6379/0

# --- Entity resolution: catastrophic-merge guard (ADR 0024) ---
# Catastrophic-merge guard (ADR 0024). 'block' (safe default) PARKS flagged PEP/sanctioned merges
# for human review; 'alert' FAILS OPEN (writes them + a merge_alerts row) and is a deliberate
# build-phase opt-in requiring sign-off — never ship 'alert' as a deployment default.
MERGE_GUARD_MODE=block

# --- Enforcement switch (ADR 0109) ---
# Master switch for the runtime safety guards (catastrophic-merge park, erasure authorization).
# "strict" (DEFAULT — the production posture) enforces every guard; "off" bypasses them ALL and
# is for a dev/test instance on test data ONLY. The per-guard overrides (true/false) win over the
# profile when set; leave them unset/commented to inherit. Disabled guards are logged loudly at
# startup. Provenance stamping is NOT toggleable (data-integrity, ADR 0109).
ENFORCEMENT_PROFILE=strict
# ENFORCE_MERGE_GUARD=
# ENFORCE_ERASURE_AUTHORIZATION=

# --- Fail-closed sensitivity guard (Gate E / ADR 0047) ---
# The sensitive-topic SET is loaded from FtM's registry.topic.RISKS (never configured). These
# tune only the Stage-2 k-hop probe depth (0 = kill-switch, hard cap 4) and the Stage-3 Chow
# abstain band [low, high) — low == high (the default) means the band is OFF; an inverted band
# (low > high) is rejected at boot.
SENSITIVITY_KHOP_DEPTH=1
SENSITIVITY_ABSTAIN_LOW=0.92
SENSITIVITY_ABSTAIN_HIGH=0.92

# Max ER-queue candidates resolved per batch (ADR 0026). resolve_pending drains
# the queue in windows of this size with a commit per batch; dedup is within a
# batch (cross-batch/incremental dedup is deferred to the ER-streaming gate).
RESOLVE_BATCH_SIZE=1000
# Ingest bounds + windowing (ADR 0027). run_ingest commits every N records, stops a
# run after the wall-clock deadline (<=0 disables), and optionally caps record count
# (unset = no cap). A bad record is dead-lettered, never aborts the run.
INGEST_COMMIT_EVERY=1000
INGEST_TIMEOUT_SECONDS=1800
# INGEST_MAX_RECORDS=
# Ingest driver cadence (ADR 0029): run each enabled connector every
# INGEST_CADENCE_SECONDS, resolve the queue every RESOLVE_CADENCE_SECONDS (its own
# cadence), waking every DRIVER_TICK_SECONDS to check what's due.
INGEST_CADENCE_SECONDS=3600
RESOLVE_CADENCE_SECONDS=300
DRIVER_TICK_SECONDS=30
# On ingest FAILURE the instance stays retryable and is rescheduled with an exponential backoff
# (ADR 0054): min(INGEST_RETRY_BASE_SECONDS * 2**(consecutive_failures-1), INGEST_RETRY_MAX_SECONDS).
# A success resets the streak back to INGEST_CADENCE_SECONDS.
INGEST_RETRY_BASE_SECONDS=60
INGEST_RETRY_MAX_SECONDS=3600
# After this many CONSECUTIVE ingest failures an instance is hard-disabled (status="error",
# terminal) instead of retrying forever (ADR 0074). 0 disables hard-disable (retry-forever).
INGEST_MAX_CONSECUTIVE_FAILURES=10
# Finished (ok/error) task_run rows older than this many days are pruned (driver maintenance)
# so the history table stays bounded (ADR 0029 follow-up). 0 disables.
TASK_RUN_RETENTION_DAYS=30
# Dead-letter (ingest_dead_letter) rows older than this many days are pruned on driver startup
# so the replayable error-audit table stays bounded (Gate B-4d / ADR 0053). 0 disables.
DEAD_LETTER_RETENTION_DAYS=30

# --- News→event LLM extraction pass (ADR 0115, Slice B) — DEFAULT OFF ---
# A driver pass that reads recent curated-feed Article nodes and, via the LLM gateway (LOCAL/
# Ollama by default), derives FtM Event + actor candidates back into the ER queue (the normal
# resolver then applies the merge guard + provenance-on-write). Flip on once Ollama is reachable
# (see the LLM gateway block below) — this is the LLM-cost switch.
EXTRACTION_ENABLED=false
EXTRACTION_CADENCE_SECONDS=900
EXTRACTION_MAX_ARTICLES_PER_CYCLE=20

# --- Driver maintenance + resolve liveness (Gate H-8b / ADR 0075) ---
# The two retention prunes now run on a PERIODIC cadence inside the driver loop (not only at
# startup), so a driver up for weeks keeps task_run / ingest_dead_letter bounded mid-uptime. The
# first tick fires, so the boot-time prune is preserved; recover_stale stays startup-only. gt=0.
MAINTENANCE_CADENCE_SECONDS=3600
# Wall-clock deadline on a single resolve pass (mirrors INGEST_TIMEOUT_SECONDS). resolve_pending
# checks it BETWEEN batches; each batch is committed first, so a timed-out pass loses no work and
# the remaining backlog resumes on the next cadence tick. <=0 disables (drain to exhaustion).
RESOLVE_TIMEOUT_SECONDS=600
# After this many CONSECUTIVE non-blocking resolve lock-skips (a prior pass still holds the lock)
# the driver escalates the skip log from info to WARNING, surfacing a wedged/starving resolve pass.
# A successful acquire resets the streak. gt=0.
RESOLVE_LOCK_SKIP_ALERT_THRESHOLD=3
# Postgres advisory-lock key the single-writer spine guard takes per promote transaction
# (ADR 0110). Relocate ONLY on a collision with another advisory-lock user; the guard itself is
# always enforced (data-integrity — not toggleable via ENFORCEMENT_PROFILE).
# SPINE_WRITER_LOCK_KEY=771100110

# --- Driver supervision & containerization (Gate B-4c / ADR 0051) ---
# /ready probes each store read-only (Postgres/Neo4j/MinIO); each probe is bounded by this
# timeout so a hung store cannot hang the readiness endpoint forever.
READINESS_PROBE_TIMEOUT_SECONDS=5
# The driver writes a last-tick heartbeat FILE here once per loop iteration; its --healthcheck
# (the container HEALTHCHECK) reads ONLY this file. Keep it on a writable per-container path.
DRIVER_HEARTBEAT_PATH=/var/run/worldmonitor/driver.heartbeat
# A heartbeat older than this many seconds is STALE -> the pipeline is reported down. Keep it a
# safe multiple of DRIVER_TICK_SECONDS (default 90s ~ 3 missed 30s ticks) so one slow tick
# does not flap the healthcheck.
DRIVER_HEARTBEAT_STALE_SECONDS=90
# Container memory caps for the supervised app services (compose mem_limit). An OOM surfaces as
# a container exit -> restart: unless-stopped restarts it. Bump on a larger host.
WM_API_MEM_LIMIT=1g
WM_DRIVER_MEM_LIMIT=1g

# --- Driver metrics exporter (Gate H-8c / ADR 0076) ---
# The driver exposes a READ-ONLY Prometheus /metrics endpoint on this port, in-network only (the
# compose driver service publishes NO host port; a scraper on the compose network hits driver:9108).
# It surfaces the H-8a/H-8b signals — instances-in-error, the in-memory resolve lock-skip counter,
# the latest resolve stopped_reason — plus the existing queue/dead-letter/task/graph counts. 0
# DISABLES the exporter entirely (no thread, no bound port) = today's behaviour / the reversal lever.
DRIVER_METRICS_PORT=9108

# --- Projection rebuild-and-diff guard (ADR 0102 / Gate 3a-ii-B) — DORMANT by default ---
# The scheduled full-fold divergence guard: folds the WHOLE statement log into an operator-
# provisioned, ISOLATED second Neo4j and measures live-graph divergence. Enable ONLY against an
# isolated target (Neo4j Community is single-database — a distinct target MUST be a distinct
# instance, never the live one). The guard runs only when the flag is true AND the URI is
# non-empty (empty URI = dormant no-op). See docs/runbooks/OPERATOR_SESSION.md §6.
PROJECTION_DIFF_ENABLED=false
PROJECTION_DIFF_NEO4J_URI=
PROJECTION_DIFF_NEO4J_USER=
PROJECTION_DIFF_NEO4J_PASSWORD=
PROJECTION_DIFF_CADENCE_SECONDS=86400

# --- Online-migration safety (ADR 0084 / audit M-5) ---
# Dialect-aware lock_timeout + statement_timeout applied per migration batch via SET LOCAL
# (Postgres-only; silently skipped elsewhere). A migration that cannot acquire its DDL lock
# FAILS FAST instead of stalling live traffic. 0 = opt out (use in the migrate-while-stopped
# runbook, docs/runbooks/migrations.md). statement_timeout defaults OFF; lock_timeout is the
# key guard.
MIGRATION_LOCK_TIMEOUT_MS=3000
MIGRATION_STATEMENT_TIMEOUT_MS=0

# --- Landing-zone orphan GC (ADR 0083 + fail-closed guard ADR 0086) — SAFE-OFF defaults ---
# Scans the landing zone for S3 objects referenced by neither er_queue_item nor
# ingest_dead_letter. Master gate OFF = the pass never runs; delete OFF = report-only (counts/
# bytes via Prometheus, nothing deleted). With deletion enabled the boot-time guard REQUIRES
# LANDING_GC_MIN_AGE_SECONDS >= INGEST_TIMEOUT_SECONDS (> 0) so an in-flight put-before-commit
# object can never be swept (ADR 0086 D1).
LANDING_GC_ENABLED=false
LANDING_GC_DELETE_ENABLED=false
LANDING_GC_MIN_AGE_SECONDS=86400

# --- GeoNames connector: local-path override hardening (Gate H-6/H-7 / ADR 0052) ---
# Default-deny: with no allowlist dir set, a connector local `path` config is REJECTED (closes the
# LFI — the connector cannot be tricked into reading /etc/passwd, /proc/self/environ, ../../.env).
# Set this to a base dir to permit local dumps under it; the resolved real-path (../ + symlinks
# resolved) must stay inside it. Leave UNSET in production.
GEONAMES_ALLOWED_PATH_DIR=
# Max bytes the connector will read from a local `path` dump (defense-in-depth size cap). 256 MiB.
GEONAMES_MAX_PATH_BYTES=268435456

# --- LLM gateway (Phase-3 S2, ADR 0091) — the single service-side LLM-egress choke point ---
# One gateway method routes every service-side LLM call through litellm, attaches the active
# mode's confidentiality label, and writes an egress record BEFORE the provider is contacted.
# Modes: local (Ollama, confidential, no egress — DEFAULT) | claude_headless (external egress,
# ToS-gray caveat) | openrouter (external egress).
LLM_MODE=local
LLM_OLLAMA_BASE_URL=http://localhost:11434
LLM_OLLAMA_MODEL=llama3.2
# Per-call wall-clock timeout (seconds) for a gateway completion — bounds a hung provider
# (notably a wedged local Ollama). 0 opts out (litellm's ~10-min default applies).
LLM_REQUEST_TIMEOUT_SECONDS=120
# OpenRouter mode:
LLM_OPENROUTER_API_KEY=
LLM_OPENROUTER_MODEL=openai/gpt-4o
# Claude-headless mode (argv-list subprocess):
LLM_CLAUDE_BINARY=claude
LLM_CLAUDE_MODEL_LABEL=claude
LLM_CLAUDE_TIMEOUT_SECONDS=30
# Egress audit: the master in-log toggle (write-before-call is never bypassed, ADR 0091 §3) +
# the durable append-only Postgres audit (ADR 0105 — requires migration 0011; when enabled, an
# EXTERNAL crossing is fail-closed on that durable write).
LLM_EGRESS_LOG_ENABLED=true
LLM_EGRESS_DURABLE_ENABLED=false

# --- Secrets ---
# Fernet key for encrypting connector configs at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONFIG_ENCRYPTION_KEY=change-me
# Decryption-only OLD keys for zero-downtime key rotation (ADR 0058), comma/space-separated.
# During a rotation, move the previous CONFIG_ENCRYPTION_KEY here so existing configs still
# decrypt; new writes use the new primary above. Empty in steady state.
CONFIG_ENCRYPTION_KEY_FALLBACKS=
MINIO_ENDPOINT=localhost:9000
# Set true only when MinIO is served over TLS (the bundled compose stack is plain HTTP).
MINIO_SECURE=false

# =====================================================================
# Compose stack credentials (deploy/compose.yaml)
# =====================================================================

# --- PostgreSQL 16 + pgvector ---
POSTGRES_USER=worldmonitor
POSTGRES_PASSWORD=change-me
POSTGRES_DB=worldmonitor
ZITADEL_DB=zitadel

# --- Neo4j 2026.x + GDS ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
# Bounded heap + pagecache + a container memory cap (heap_max + pagecache + ~1g
# overhead must stay BELOW NEO4J_MEM_LIMIT). Laptop/WSL2-safe defaults below; an
# unbounded heap on WSL2 OOM-kills Neo4j before it binds 7687.
NEO4J_HEAP_INITIAL=1g
NEO4J_HEAP_MAX=2g
NEO4J_PAGECACHE=512m
NEO4J_MEM_LIMIT=4g
# Production (per docs/10_ARCHITECTURE.md "bounded heap+pagecache ~16-24 GB", 64 GB host):
#   NEO4J_HEAP_INITIAL=8g  NEO4J_HEAP_MAX=8g  NEO4J_PAGECACHE=16g  NEO4J_MEM_LIMIT=26g

# --- MinIO ---
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me
# The app's S3 credentials (must match the root creds above) + landing bucket.
MINIO_ACCESS_KEY=worldmonitor
MINIO_SECRET_KEY=change-me
LANDING_BUCKET=landing

# --- Redis ---
REDIS_PASSWORD=change-me

# --- Zitadel ---
# ZITADEL_MASTERKEY MUST be exactly 32 characters.
# generate: openssl rand -hex 16
ZITADEL_MASTERKEY=change-me-32-chars-xxxxxxxxxxxxx
ZITADEL_EXTERNALDOMAIN=localhost
ZITADEL_EXTERNALPORT=8080
ZITADEL_ORG_NAME=WorldMonitor
ZITADEL_ADMIN_USERNAME=admin
ZITADEL_ADMIN_PASSWORD=change-me
ZITADEL_ADMIN_EMAIL=admin@worldmonitor.localhost
ZITADEL_SA_USERNAME=provisioner

# --- ACTIVE heavy-tool container sandbox (ADR 0072 §1 + ADR 0077) ---
# Gate for container-level ACTIVE CLI tools (e.g. nmap). DEFAULT false: every container-level
# tool's EXECUTION is refused (409) before any subprocess/landing; subprocess-level tools
# (whois/dig) are unaffected. Flipping true alone NEVER runs nmap un-sandboxed — the sidecar
# URL + secret below must ALSO be set (INV-2).
CONTAINER_SANDBOX_ENABLED=false

# --- Sandbox-runner sidecar (ADR 0077) ---
# The in-network sidecar that runs heavy container-level ACTIVE CLI tools (e.g. nmap) with
# constrained egress. The app-side ContainerRunner POSTs {argv, timeout} to SANDBOX_RUNNER_URL with
# the shared secret in the X-Sandbox-Secret header. BOTH EMPTY (the default) => container-level
# tools stay REFUSED even with CONTAINER_SANDBOX_ENABLED=true (the flag alone NEVER runs nmap
# un-sandboxed). Set both + the flag to route container tools through the sidecar. (Slice 2 ships
# the actual sandbox-runner service + Dockerfile stage + network-isolation egress; nftables
# metadata/RFC1918 denial is deferred.) For the bundled compose stack the api/driver already
# default SANDBOX_RUNNER_URL=http://sandbox-runner:9101 (the in-network sidecar; no host port) —
# leave these EMPTY here and CONTAINER_SANDBOX_ENABLED OFF until the operator opts in.
SANDBOX_RUNNER_URL=
SANDBOX_RUNNER_SECRET=
