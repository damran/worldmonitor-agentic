# WorldMonitor environment — copy to `.env` and fill in. NEVER commit `.env`.
# Placeholders only (no real secrets). Replace every `change-me`.
# Non-development boots (ENVIRONMENT != development) REJECT `change-me` placeholders at
# startup and halt loud (ADR 0061) — fill in real secrets before deploying.

# --- App ---
ENVIRONMENT=development

# --- Zitadel / OIDC (the API validates bearer tokens against this) ---
# After `docker compose up`, run scripts/dev/zitadel_provision.sh to create the
# OIDC apps, then paste the values it prints below.
ZITADEL_DOMAIN=localhost:8080
ZITADEL_CLIENT_ID=

# --- Backing-service URLs the app connects to ---
NEO4J_URI=bolt://localhost:7687
POSTGRES_DSN=postgresql://worldmonitor:change-me@localhost:5432/worldmonitor
REDIS_URL=redis://:change-me@localhost:6379/0

# --- Entity resolution: catastrophic-merge guard (ADR 0024) ---
# Catastrophic-merge guard (ADR 0024). 'block' (safe default) PARKS flagged PEP/sanctioned merges
# for human review; 'alert' FAILS OPEN (writes them + a merge_alerts row) and is a deliberate
# build-phase opt-in requiring sign-off — never ship 'alert' as a deployment default.
MERGE_GUARD_MODE=block
# Max ER-queue candidates resolved per batch (ADR 0026). resolve_pending drains
# the queue in windows of this size with a commit per batch; dedup is within a
# batch (cross-batch/incremental dedup is deferred to the ER-streaming gate).
RESOLVE_BATCH_SIZE=1000
# Ingest bounds + windowing (ADR 0027). run_ingest commits every N records, stops a
# run after the wall-clock deadline (<=0 disables), and optionally caps record count
# (unset = no cap). A bad record is dead-lettered, never aborts the run.
INGEST_COMMIT_EVERY=1000
INGEST_TIMEOUT_SECONDS=1800
# INGEST_MAX_RECORDS=
# Ingest driver cadence (ADR 0029): run each enabled connector every
# INGEST_CADENCE_SECONDS, resolve the queue every RESOLVE_CADENCE_SECONDS (its own
# cadence), waking every DRIVER_TICK_SECONDS to check what's due.
INGEST_CADENCE_SECONDS=3600
RESOLVE_CADENCE_SECONDS=300
DRIVER_TICK_SECONDS=30
# On ingest FAILURE the instance stays retryable and is rescheduled with an exponential backoff
# (ADR 0054): min(INGEST_RETRY_BASE_SECONDS * 2**(consecutive_failures-1), INGEST_RETRY_MAX_SECONDS).
# A success resets the streak back to INGEST_CADENCE_SECONDS.
INGEST_RETRY_BASE_SECONDS=60
INGEST_RETRY_MAX_SECONDS=3600
# Dead-letter (ingest_dead_letter) rows older than this many days are pruned on driver startup
# so the replayable error-audit table stays bounded (Gate B-4d / ADR 0053). 0 disables.
DEAD_LETTER_RETENTION_DAYS=30

# --- Driver maintenance + resolve liveness (Gate H-8b / ADR 0075) ---
# The two retention prunes now run on a PERIODIC cadence inside the driver loop (not only at
# startup), so a driver up for weeks keeps task_run / ingest_dead_letter bounded mid-uptime. The
# first tick fires, so the boot-time prune is preserved; recover_stale stays startup-only. gt=0.
MAINTENANCE_CADENCE_SECONDS=3600
# Wall-clock deadline on a single resolve pass (mirrors INGEST_TIMEOUT_SECONDS). resolve_pending
# checks it BETWEEN batches; each batch is committed first, so a timed-out pass loses no work and
# the remaining backlog resumes on the next cadence tick. <=0 disables (drain to exhaustion).
RESOLVE_TIMEOUT_SECONDS=600
# After this many CONSECUTIVE non-blocking resolve lock-skips (a prior pass still holds the lock)
# the driver escalates the skip log from info to WARNING, surfacing a wedged/starving resolve pass.
# A successful acquire resets the streak. gt=0.
RESOLVE_LOCK_SKIP_ALERT_THRESHOLD=3

# --- Driver supervision & containerization (Gate B-4c / ADR 0051) ---
# /ready probes each store read-only (Postgres/Neo4j/MinIO); each probe is bounded by this
# timeout so a hung store cannot hang the readiness endpoint forever.
READINESS_PROBE_TIMEOUT_SECONDS=5
# The driver writes a last-tick heartbeat FILE here once per loop iteration; its --healthcheck
# (the container HEALTHCHECK) reads ONLY this file. Keep it on a writable per-container path.
DRIVER_HEARTBEAT_PATH=/var/run/worldmonitor/driver.heartbeat
# A heartbeat older than this many seconds is STALE -> the pipeline is reported down. Keep it a
# safe multiple of DRIVER_TICK_SECONDS (default 90s ~ 3 missed 30s ticks) so one slow tick
# does not flap the healthcheck.
DRIVER_HEARTBEAT_STALE_SECONDS=90
# Container memory caps for the supervised app services (compose mem_limit). An OOM surfaces as
# a container exit -> restart: unless-stopped restarts it. Bump on a larger host.
WM_API_MEM_LIMIT=1g
WM_DRIVER_MEM_LIMIT=1g

# --- GeoNames connector: local-path override hardening (Gate H-6/H-7 / ADR 0052) ---
# Default-deny: with no allowlist dir set, a connector local `path` config is REJECTED (closes the
# LFI — the connector cannot be tricked into reading /etc/passwd, /proc/self/environ, ../../.env).
# Set this to a base dir to permit local dumps under it; the resolved real-path (../ + symlinks
# resolved) must stay inside it. Leave UNSET in production.
GEONAMES_ALLOWED_PATH_DIR=
# Max bytes the connector will read from a local `path` dump (defense-in-depth size cap). 256 MiB.
GEONAMES_MAX_PATH_BYTES=268435456

# --- Secrets ---
# Fernet key for encrypting connector configs at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONFIG_ENCRYPTION_KEY=change-me
# Decryption-only OLD keys for zero-downtime key rotation (ADR 0058), comma/space-separated.
# During a rotation, move the previous CONFIG_ENCRYPTION_KEY here so existing configs still
# decrypt; new writes use the new primary above. Empty in steady state.
CONFIG_ENCRYPTION_KEY_FALLBACKS=
MINIO_ENDPOINT=localhost:9000

# =====================================================================
# Compose stack credentials (deploy/compose.yaml)
# =====================================================================

# --- PostgreSQL 16 + pgvector ---
POSTGRES_USER=worldmonitor
POSTGRES_PASSWORD=change-me
POSTGRES_DB=worldmonitor
ZITADEL_DB=zitadel

# --- Neo4j 2026.x + GDS ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
# Bounded heap + pagecache + a container memory cap (heap_max + pagecache + ~1g
# overhead must stay BELOW NEO4J_MEM_LIMIT). Laptop/WSL2-safe defaults below; an
# unbounded heap on WSL2 OOM-kills Neo4j before it binds 7687.
NEO4J_HEAP_INITIAL=1g
NEO4J_HEAP_MAX=2g
NEO4J_PAGECACHE=512m
NEO4J_MEM_LIMIT=4g
# Production (per docs/10_ARCHITECTURE.md "bounded heap+pagecache ~16-24 GB", 64 GB host):
#   NEO4J_HEAP_INITIAL=8g  NEO4J_HEAP_MAX=8g  NEO4J_PAGECACHE=16g  NEO4J_MEM_LIMIT=26g

# --- MinIO ---
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me
# The app's S3 credentials (must match the root creds above) + landing bucket.
MINIO_ACCESS_KEY=worldmonitor
MINIO_SECRET_KEY=change-me
LANDING_BUCKET=landing

# --- Redis ---
REDIS_PASSWORD=change-me

# --- Zitadel ---
# ZITADEL_MASTERKEY MUST be exactly 32 characters.
# generate: openssl rand -hex 16
ZITADEL_MASTERKEY=change-me-32-chars-xxxxxxxxxxxxx
ZITADEL_EXTERNALDOMAIN=localhost
ZITADEL_EXTERNALPORT=8080
ZITADEL_ORG_NAME=WorldMonitor
ZITADEL_ADMIN_USERNAME=admin
ZITADEL_ADMIN_PASSWORD=change-me
ZITADEL_ADMIN_EMAIL=admin@worldmonitor.localhost
ZITADEL_SA_USERNAME=provisioner
