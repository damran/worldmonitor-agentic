# WorldMonitor environment — copy to `.env` and fill in. NEVER commit `.env`.
# This file holds placeholders only (no real secrets).

# --- App ---
ENVIRONMENT=development

# --- Zitadel / OIDC (the API validates bearer tokens against this) ---
# ZITADEL_DOMAIN is the issuer host, e.g. worldmonitor.localhost or your instance domain.
ZITADEL_DOMAIN=
ZITADEL_CLIENT_ID=

# --- Backing services (URLs the app connects to) ---
NEO4J_URI=bolt://localhost:7687
POSTGRES_DSN=postgresql://worldmonitor:change-me@localhost:5432/worldmonitor
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9000
