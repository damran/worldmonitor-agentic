# ---- Python ----
__pycache__/
*.py[cod]
*.egg
*.egg-info/
.eggs/
build/
dist/
.Python

# Virtual envs
.venv/
venv/
env/

# Test / lint / type caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyright/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/

# ---- Secrets & env (never commit) ----
.env
.env.*
!.env.example

# ---- Vendored read-only reference clones ----
vendor-repos/

# ---- Local data / volumes ----
data/
*.db
*.duckdb

# ---- Claude Code local-only settings ----
.claude/settings.local.json

# ---- Fleet / agentic build harness: runtime & ephemeral state (never commit) ----
# The committed governance layer is .claude/agents/, .claude/hooks/, settings.json.
# Everything below is per-run working state or local operational tooling.
.claude/gate.scope
.claude/continue
.claude/*.log
.claude/fleet.status.json
.claude/fleet.budget.json
# Operational tooling kept local (not product code; not held to product lint/type gates)
orchestrator/
scripts/council/
scripts/smoke/
scripts/dev/fleet_status.sh
scripts/dev/fleet_watch.sh
scripts/dev/spawn_worker.sh
scripts/dev/orient.sh
scripts/dev/local_ci.sh

# ---- OS / editor cruft ----
*:Zone.Identifier
.DS_Store
Thumbs.db
*.swp
*~
.idea/

# Local git bundle artifact (never commit)
*.bundle
